{
  "ConnectionStrings": {
    "ExamRunnerDb": "Data Source=App_Data/exam-runner.db"
  },
  "Desktop": {
    "Enabled": false,
    "AppDirectoryName": "ExamRunner",
    "Cors": {
      "AllowNullOrigin": false,
      "AllowedOrigins": [
        "app://-"
      ]
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
