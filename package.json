{
  "name": "exam-runner-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "api:dev": "dotnet watch --project apps/api/src/ExamRunner.Api run",
    "api:build": "dotnet build apps/api/ExamRunner.sln",
    "api:test": "dotnet test apps/api/ExamRunner.sln",
    "api:lint": "dotnet format apps/api/ExamRunner.sln --verify-no-changes",
    "api:openapi": "bash ./scripts/export-openapi.sh",
    "web:api:generate": "pnpm --filter @exam-runner/web run generate:api",
    "contracts:generate": "pnpm api:openapi && pnpm web:api:generate",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down",
    "api:seed": "bash ./scripts/seed-example-exam.sh"
  }
}
