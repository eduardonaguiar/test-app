{
  "name": "exam-runner-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "bash -lc \"pnpm run dev:api & pnpm run dev:web\"",
    "build": "pnpm run build:js && pnpm run build:api",
    "lint": "pnpm run format:check && pnpm run lint:js && pnpm run lint:js:a11y && pnpm run lint:api",
    "test": "pnpm run test:js && pnpm run test:js:a11y && pnpm run test:api",
    "typecheck": "pnpm run typecheck:js && pnpm run typecheck:api",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down",
    "db:migrate": "bash ./scripts/db-migrate.sh",
    "db:seed": "bash ./scripts/seed-demo-exams.sh",
    "dev:web": "pnpm --filter @exam-runner/web dev",
    "dev:api": "dotnet watch --project apps/api/src/ExamRunner.Api run",
    "build:js": "pnpm -r --if-present build",
    "build:api": "dotnet build apps/api/ExamRunner.sln",
    "lint:js": "pnpm -r --if-present lint",
    "lint:js:a11y": "pnpm --filter @exam-runner/web lint:a11y",
    "lint:api": "dotnet format apps/api/ExamRunner.sln --verify-no-changes",
    "test:js": "pnpm -r test",
    "test:js:a11y": "pnpm --filter @exam-runner/web test:a11y",
    "test:api": "dotnet test apps/api/ExamRunner.sln",
    "typecheck:js": "pnpm -r --if-present typecheck",
    "typecheck:api": "dotnet build apps/api/ExamRunner.sln --no-restore",
    "api:openapi": "bash ./scripts/export-openapi.sh",
    "web:api:generate": "pnpm --filter @exam-runner/web run generate:api",
    "contracts:generate": "pnpm api:openapi && pnpm web:api:generate",
    "format": "pnpm run format:js && pnpm run format:api",
    "format:check": "pnpm run format:check:js && pnpm run format:check:api",
    "format:js": "pnpm --filter @exam-runner/web format",
    "format:check:js": "pnpm --filter @exam-runner/web format:check",
    "format:api": "dotnet format apps/api/ExamRunner.sln",
    "format:check:api": "dotnet format apps/api/ExamRunner.sln --verify-no-changes",
    "db:seed:example": "bash ./scripts/seed-example-exam.sh",
    "desktop:dev": "pnpm --filter @exam-runner/desktop dev",
    "desktop:package": "pnpm run desktop:artifacts:prepare && pnpm --filter @exam-runner/desktop package",
    "desktop:make": "pnpm run desktop:artifacts:prepare && pnpm --filter @exam-runner/desktop make",
    "dev:desktop": "pnpm --filter @exam-runner/desktop dev",
    "build:desktop": "pnpm run desktop:package",
    "make:desktop": "pnpm run desktop:make",
    "build:web": "pnpm --filter @exam-runner/web build",
    "desktop:web:prepare": "pnpm --filter @exam-runner/web build --mode desktop && node ./scripts/prepare-desktop-web.mjs",
    "desktop:artifacts:prepare": "pnpm run desktop:web:prepare && pnpm run api:publish:win-x64",
    "api:publish:win-x64": "bash ./scripts/publish-api-win-x64.sh",
    "desktop:installer:win": "bash ./scripts/build-desktop-installer-win.sh",
    "desktop:smoke": "bash ./scripts/smoke-test-desktop-artifacts.sh"
  }
}
