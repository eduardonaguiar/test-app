{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exam-runner.local/contracts/exam-schema/v1/exam.schema.json",
  "title": "Exam Import Schema",
  "description": "Official schema for exam import JSON files.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "metadata",
    "durationMinutes",
    "passingScore",
    "reconnectPolicy",
    "sections"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version expected by the importer."
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "durationMinutes": {
      "type": "integer",
      "minimum": 1,
      "description": "Official exam duration in minutes."
    },
    "passingScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Minimum score needed to pass, in percentage."
    },
    "reconnectPolicy": {
      "$ref": "#/$defs/reconnectPolicy"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "examId",
        "title"
      ],
      "properties": {
        "examId": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "reconnectPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "maxReconnects",
        "gracePeriodSeconds",
        "terminateIfExceeded"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxReconnects": {
          "type": "integer",
          "minimum": 0
        },
        "gracePeriodSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "terminateIfExceeded": {
          "type": "boolean"
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sectionId",
        "title",
        "questions"
      ],
      "properties": {
        "sectionId": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/question"
          }
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "questionId",
        "prompt",
        "options",
        "correctOptionId",
        "explanationSummary",
        "explanationDetailed",
        "topic",
        "difficulty",
        "weight"
      ],
      "properties": {
        "questionId": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/option"
          }
        },
        "correctOptionId": {
          "type": "string",
          "minLength": 1
        },
        "explanationSummary": {
          "type": "string",
          "minLength": 1
        },
        "explanationDetailed": {
          "type": "string",
          "minLength": 1
        },
        "topic": {
          "type": "string",
          "minLength": 1
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "easy",
            "medium",
            "hard"
          ]
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "optionId",
        "text"
      ],
      "properties": {
        "optionId": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
